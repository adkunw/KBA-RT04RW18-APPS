<h1>Portal Dashboard</h1>

<div
  style="
    background: #f0f4ff;
    padding: 1.5rem;
    border-radius: 4px;
    margin-bottom: 1.5rem;
  "
>
  <h2 style="color: #667eea; margin-bottom: 0.5rem">
    Welcome, <%= user.name %>!
  </h2>
  <p style="color: #555">
    You have successfully logged in to the RT Management System. This is your
    personal portal.
  </p>
</div>

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem">
  <div
    style="
      background: white;
      border: 1px solid #e0e0e0;
      padding: 1.5rem;
      border-radius: 4px;
      border-left: 4px solid #667eea;
    "
  >
    <h3 style="color: #333; margin-bottom: 0.5rem">📋 My Information</h3>
    <p style="color: #666; font-size: 0.9rem">
      View and manage your personal information.
    </p>
  </div>

  <div
    style="
      background: white;
      border: 1px solid #e0e0e0;
      padding: 1.5rem;
      border-radius: 4px;
      border-left: 4px solid #764ba2;
    "
  >
    <h3 style="color: #333; margin-bottom: 0.5rem">📢 Announcements</h3>
    <p style="color: #666; font-size: 0.9rem">
      Stay updated with community news and important announcements.
    </p>
  </div>
</div>

<div
  style="
    margin-top: 1.5rem;
    padding: 1rem;
    background: #f9f9f9;
    border-radius: 4px;
  "
>
  <p style="color: #666; font-size: 0.9rem; margin: 0">
    Portal functionality coming soon. Additional features will be available
    soon.
  </p>
</div>
