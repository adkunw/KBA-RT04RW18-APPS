<h1>✅ Account Activated</h1>

<div
  style="
    background: #d4edda;
    border: 1px solid #c3e6cb;
    border-left: 4px solid #28a745;
    padding: 1.5rem;
    border-radius: 4px;
    margin-bottom: 1.5rem;
    text-align: center;
  "
>
  <h2 style="color: #155724; margin-top: 0">Welcome, <%= user.name %>!</h2>
  <p style="color: #155724; margin-bottom: 0">
    Your account has been successfully activated.
  </p>
</div>

<div
  style="
    background: white;
    border: 1px solid #ddd;
    padding: 1.5rem;
    border-radius: 4px;
    margin-bottom: 1.5rem;
    text-align: center;
  "
>
  <h3 style="color: #333">You can now log in</h3>
  <p style="color: #666; margin-bottom: 1.5rem">
    Use your phone number and password to log in to your account.
  </p>
  <a
    href="/auth/login"
    style="
      display: inline-block;
      background: #667eea;
      color: white;
      padding: 0.75rem 2rem;
      border-radius: 4px;
      text-decoration: none;
      font-weight: 500;
      transition: background 0.3s ease;
    "
    onmouseover="this.style.background = '#5568d3'"
    onmouseout="this.style.background = '#667eea'"
  >
    Go to Login →
  </a>
</div>

<div
  style="
    background: #f0f4ff;
    border-left: 4px solid #667eea;
    padding: 1rem;
    border-radius: 4px;
  "
>
  <p style="color: #555; margin: 0; font-size: 0.9rem">
    <strong>Login Details:</strong><br />
    Phone:
    <code style="background: white; padding: 2px 4px; border-radius: 2px"
      ><%= user.phone %></code
    ><br />
    Password: [The password you just entered]
  </p>
</div>
