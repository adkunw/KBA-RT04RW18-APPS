<h1>Admin Dashboard</h1>

<div
  style="
    background: #f0f4ff;
    padding: 1.5rem;
    border-radius: 4px;
    margin-bottom: 1.5rem;
  "
>
  <h2 style="color: #667eea; margin-bottom: 0.5rem">
    Welcome, <%= user.name %>!
  </h2>
  <p style="color: #555">
    You have admin access to the RT Management System. This is your control
    center.
  </p>
  <p style="color: #666; font-size: 0.9rem; margin-top: 0.5rem">
    <strong>Roles:</strong> <%= user.roles.join(', ') %>
  </p>
</div>

<div
  style="
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
  "
>
  <div
    style="
      background: white;
      border: 1px solid #e0e0e0;
      padding: 1.5rem;
      border-radius: 4px;
      border-left: 4px solid #667eea;
    "
  >
    <h3 style="color: #333; margin-bottom: 0.5rem">👥 Member Management</h3>
    <p style="color: #666; font-size: 0.9rem; margin-bottom: 1rem">
      Manage RT members and their details
    </p>
    <a
      href="/admin/users"
      style="
        display: inline-block;
        background: #667eea;
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 4px;
        text-decoration: none;
        font-size: 0.9rem;
      "
    >
      Manage Members →
    </a>
  </div>

  <div
    style="
      background: white;
      border: 1px solid #e0e0e0;
      padding: 1.5rem;
      border-radius: 4px;
      border-left: 4px solid #764ba2;
    "
  >
    <h3 style="color: #333; margin-bottom: 0.5rem">🔐 Roles & Permissions</h3>
    <p style="color: #666; font-size: 0.9rem; margin-bottom: 1rem">
      Configure roles and access permissions
    </p>
    <a
      href="/admin/roles"
      style="
        display: inline-block;
        background: #764ba2;
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 4px;
        text-decoration: none;
        font-size: 0.9rem;
      "
    >
      Manage Roles →
    </a>
  </div>

  <div
    style="
      background: white;
      border: 1px solid #e0e0e0;
      padding: 1.5rem;
      border-radius: 4px;
      border-left: 4px solid #ff9800;
    "
  >
    <h3 style="color: #333; margin-bottom: 0.5rem">📊 System Information</h3>
    <p style="color: #666; font-size: 0.9rem; margin-bottom: 1rem">
      View system statistics and logs
    </p>
    <a
      href="/admin/system"
      style="
        display: inline-block;
        background: #ff9800;
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 4px;
        text-decoration: none;
        font-size: 0.9rem;
      "
    >
      System Info →
    </a>
  </div>
</div>

<div
  style="
    background: #fff3cd;
    border: 1px solid #ffc107;
    border-radius: 4px;
    padding: 1rem;
    margin-bottom: 1.5rem;
  "
>
  <p style="color: #856404; margin: 0; font-size: 0.9rem">
    <strong>⚠️ Note:</strong> Admin panel is under construction. Additional
    features will be available soon.
  </p>
</div>

<div style="text-align: center">
  <a
    href="/portal"
    style="
      display: inline-block;
      background: #ddd;
      color: #333;
      padding: 0.75rem 1.5rem;
      border-radius: 4px;
      text-decoration: none;
      font-weight: 500;
    "
  >
    ← Back to Portal
  </a>
</div>
