<h1>✅ User Created Successfully</h1>

<div
  style="
    background: #d4edda;
    border: 1px solid #c3e6cb;
    border-left: 4px solid #28a745;
    padding: 1rem;
    border-radius: 4px;
    margin-bottom: 1.5rem;
  "
>
  <p style="color: #155724; margin: 0">
    User <strong><%= user.name %></strong> has been created with phone
    <strong><%= user.phone %></strong>.
  </p>
</div>

<div
  style="
    background: white;
    border: 1px solid #ddd;
    padding: 1.5rem;
    border-radius: 4px;
    margin-bottom: 1.5rem;
  "
>
  <h2 style="color: #333; margin-top: 0">Activation Link</h2>
  <p style="color: #666; margin-bottom: 1rem">
    Share this link with the user so they can activate their account and set a
    password:
  </p>

  <div
    style="
      background: #f5f5f5;
      padding: 1rem;
      border: 1px solid #ddd;
      border-radius: 4px;
      margin-bottom: 1rem;
      word-break: break-all;
    "
  >
    <code style="color: #333; font-family: monospace"
      ><%= activationLink %></code
    >
  </div>

  <p style="color: #666; font-size: 0.9rem; margin-bottom: 1rem">
    <strong>Token:</strong>
    <code style="background: #f0f0f0; padding: 2px 4px; border-radius: 2px"
      ><%= activationToken.substring(0, 16) %>...</code
    >
  </p>

  <div
    style="
      background: #fff3cd;
      border: 1px solid #ffc107;
      border-left: 4px solid #ff9800;
      padding: 1rem;
      border-radius: 4px;
    "
  >
    <p style="color: #856404; margin: 0; font-size: 0.9rem">
      <strong>⚠️ Important:</strong> This link will expire in 24 hours. The link
      is one-time use only.
    </p>
  </div>
</div>

<div
  style="
    background: white;
    border: 1px solid #ddd;
    padding: 1.5rem;
    border-radius: 4px;
    margin-bottom: 1.5rem;
  "
>
  <h2 style="color: #333; margin-top: 0">Next Steps</h2>
  <ol style="color: #555; line-height: 1.8">
    <li>Send the activation link to the user</li>
    <li>User clicks the link and sets their password</li>
    <li>
      User's account status automatically changes to <strong>ACTIVE</strong>
    </li>
    <li>User can then log in with their phone and password</li>
  </ol>
</div>

<div style="display: flex; gap: 1rem">
  <a
    href="/admin/users"
    style="
      display: inline-block;
      background: #667eea;
      color: white;
      padding: 0.75rem 1.5rem;
      border-radius: 4px;
      text-decoration: none;
      font-weight: 500;
    "
  >
    Back to User List
  </a>
  <a
    href="/admin/users/create"
    style="
      display: inline-block;
      background: #764ba2;
      color: white;
      padding: 0.75rem 1.5rem;
      border-radius: 4px;
      text-decoration: none;
      font-weight: 500;
    "
  >
    Create Another User
  </a>
</div>
