<h1>User Management</h1>

<div style="margin-bottom: 1.5rem;">
  <a href="/admin/users/create" style="
    display: inline-block;
    background: #667eea;
    color: white;
    padding: 0.75rem 1.5rem;
    border-radius: 4px;
    text-decoration: none;
    font-weight: 500;
    transition: background 0.3s ease;
  " onmouseover="this.style.background='#5568d3'" onmouseout="this.style.background='#667eea'">
    + Create New User
  </a>
</div>

<% if (users.length === 0) { %>
  <div style="
    background: #f0f4ff;
    border: 1px solid #667eea;
    padding: 2rem;
    border-radius: 4px;
    text-align: center;
  ">
    <p style="color: #666; margin: 0;">No users found. <a href="/admin/users/create">Create one</a></p>
  </div>
<% } else { %>
  <div style="
    background: white;
    border: 1px solid #ddd;
    border-radius: 4px;
    overflow: hidden;
  ">
    <table style="
      width: 100%;
      border-collapse: collapse;
    ">
      <thead>
        <tr style="background: #f5f5f5;">
          <th style="padding: 1rem; text-align: left; border-bottom: 2px solid #ddd;">Name</th>
          <th style="padding: 1rem; text-align: left; border-bottom: 2px solid #ddd;">Phone</th>
          <th style="padding: 1rem; text-align: left; border-bottom: 2px solid #ddd;">Status</th>
          <th style="padding: 1rem; text-align: left; border-bottom: 2px solid #ddd;">Roles</th>
          <th style="padding: 1rem; text-align: left; border-bottom: 2px solid #ddd;">Created</th>
          <th style="padding: 1rem; text-align: center; border-bottom: 2px solid #ddd;">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(user => { %>
          <tr style="border-bottom: 1px solid #eee;">
            <td style="padding: 1rem;"><%= user.name %></td>
            <td style="padding: 1rem;"><%= user.phone %></td>
            <td style="padding: 1rem;">
              <span style="
                display: inline-block;
                padding: 0.25rem 0.75rem;
                border-radius: 3px;
                font-size: 0.8rem;
                font-weight: 500;
                background: <%= user.status === 'active' ? '#d4edda' : '#fff3cd' %>;
                color: <%= user.status === 'active' ? '#155724' : '#856404' %>;
              ">
                <%= user.status.toUpperCase() %>
              </span>
            </td>
            <td style="padding: 1rem;">
              <% if (user.roles.length > 0) { %>
                <%= user.roles.map(ur => ur.role.name).join(', ') %>
              <% } else { %>
                <span style="color: #999;">No roles</span>
              <% } %>
            </td>
            <td style="padding: 1rem; font-size: 0.9rem; color: #666;">
              <%= new Date(user.createdAt).toLocaleDateString() %>
            </td>
            <td style="padding: 1rem; text-align: center;">
              <a href="/admin/users/<%= user.id %>" style="
                display: inline-block;
                background: #667eea;
                color: white;
                padding: 0.5rem 1rem;
                border-radius: 3px;
                text-decoration: none;
                font-size: 0.8rem;
              ">
                View
              </a>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  <% if (totalPages > 1) { %>
    <div style="
      margin-top: 1.5rem;
      display: flex;
      justify-content: center;
      gap: 0.5rem;
    ">
      <% for (let page = 1; page <= totalPages; page++) { %>
        <% if (page === currentPage) { %>
          <span style="
            padding: 0.5rem 1rem;
            background: #667eea;
            color: white;
            border-radius: 3px;
            font-weight: 500;
          ">
            <%= page %>
          </span>
        <% } else { %>
          <a href="/admin/users?page=<%= page %>" style="
            padding: 0.5rem 1rem;
            background: #f0f0f0;
            color: #333;
            border-radius: 3px;
            text-decoration: none;
          ">
            <%= page %>
          </a>
        <% } %>
      <% } %>
    </div>
  <% } %>
<% } %>

<div style="margin-top: 2rem; text-align: center;">
  <a href="/admin" style="
    display: inline-block;
    background: #ddd;
    color: #333;
    padding: 0.75rem 1.5rem;
    border-radius: 4px;
    text-decoration: none;
    font-weight: 500;
  ">
    ← Back to Admin Panel
  </a>
</div>
