<h1><%= viewedUser.name %></h1>

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem;">
  <div style="
    background: white;
    border: 1px solid #ddd;
    padding: 1.5rem;
    border-radius: 4px;
  ">
    <h2 style="color: #667eea; margin-top: 0; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px;">Profile</h2>
    <table style="width: 100%; border-collapse: collapse;">
      <tr>
        <td style="padding: 0.5rem 0; font-weight: 500; color: #666; width: 40%;">Name:</td>
        <td style="padding: 0.5rem 0;"><%= viewedUser.name %></td>
      </tr>
      <tr>
        <td style="padding: 0.5rem 0; font-weight: 500; color: #666;">Phone:</td>
        <td style="padding: 0.5rem 0;"><%= viewedUser.phone %></td>
      </tr>
      <tr>
        <td style="padding: 0.5rem 0; font-weight: 500; color: #666;">Status:</td>
        <td style="padding: 0.5rem 0;">
          <span style="
            display: inline-block;
            padding: 0.25rem 0.75rem;
            border-radius: 3px;
            font-size: 0.8rem;
            font-weight: 500;
            background: <%= viewedUser.status === 'active' ? '#d4edda' : '#fff3cd' %>;
            color: <%= viewedUser.status === 'active' ? '#155724' : '#856404' %>;
          ">
            <%= viewedUser.status.toUpperCase() %>
          </span>
        </td>
      </tr>
      <tr>
        <td style="padding: 0.5rem 0; font-weight: 500; color: #666;">Member Since:</td>
        <td style="padding: 0.5rem 0;">
          <%= new Date(viewedUser.createdAt).toLocaleDateString('id-ID', {
            year: 'numeric',
            month: 'long',
            day: 'numeric'
          }) %>
        </td>
      </tr>
      <% if (viewedUser.lastLogin) { %>
        <tr>
          <td style="padding: 0.5rem 0; font-weight: 500; color: #666;">Last Login:</td>
          <td style="padding: 0.5rem 0;">
            <%= new Date(viewedUser.lastLogin).toLocaleString('id-ID') %>
          </td>
        </tr>
      <% } %>
    </table>
  </div>

  <div style="
    background: white;
    border: 1px solid #ddd;
    padding: 1.5rem;
    border-radius: 4px;
  ">
    <h2 style="color: #764ba2; margin-top: 0; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px;">Assigned Roles</h2>
    <% if (viewedUser.roles.length > 0) { %>
      <ul style="list-style: none; padding: 0; margin: 0;">
        <% viewedUser.roles.forEach(ur => { %>
          <li style="
            padding: 0.75rem;
            background: #f5f5f5;
            margin-bottom: 0.5rem;
            border-radius: 3px;
            border-left: 3px solid #764ba2;
          ">
            <strong><%= ur.role.name %></strong>
            <% if (ur.role.permissions.length > 0) { %>
              <div style="font-size: 0.85rem; color: #666; margin-top: 0.5rem;">
                Permissions: 
                <span style="background: #e8f0ff; padding: 2px 6px; border-radius: 2px;">
                  <%= ur.role.permissions.map(rp => rp.permission.name).join(', ') %>
                </span>
              </div>
            <% } %>
          </li>
        <% }); %>
      </ul>
    <% } else { %>
      <p style="color: #999;">No roles assigned</p>
    <% } %>
  </div>
</div>

<% if (viewedUser.status === 'created') { %>
  <div style="
    background: #fff3cd;
    border: 1px solid #ffc107;
    border-left: 4px solid #ff9800;
    padding: 1rem;
    border-radius: 4px;
    margin-bottom: 1.5rem;
  ">
    <p style="color: #856404; margin: 0; font-size: 0.9rem;">
      <strong>⚠️ Pending Activation:</strong> This user hasn't activated their account yet. Please share the activation link with them.
    </p>
  </div>
<% } %>

<div style="display: flex; gap: 1rem;">
  <a href="/admin/users" style="
    display: inline-block;
    background: #ddd;
    color: #333;
    padding: 0.75rem 1.5rem;
    border-radius: 4px;
    text-decoration: none;
    font-weight: 500;
  ">
    ← Back to Users
  </a>
</div>
