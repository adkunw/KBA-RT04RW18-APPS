<h1>403 - Access Denied</h1>

<p style="color: #666; margin-bottom: 1.5rem"><%= message %></p>

<p style="color: #666; margin-bottom: 1.5rem">
  You do not have the necessary permissions to access this resource. If you
  believe this is an error, please contact the system administrator.
</p>

<div style="text-align: center">
  <a
    href="/"
    style="
      display: inline-block;
      background: #667eea;
      color: white;
      padding: 0.75rem 2rem;
      border-radius: 4px;
      text-decoration: none;
      font-weight: 500;
      margin-right: 1rem;
    "
  >
    ← Back to Home
  </a>
  <a
    href="/portal"
    style="
      display: inline-block;
      background: #764ba2;
      color: white;
      padding: 0.75rem 2rem;
      border-radius: 4px;
      text-decoration: none;
      font-weight: 500;
    "
  >
    Go to Portal
  </a>
</div>
