<h1>500 - Server Error</h1>

<p style="color: #666; margin-bottom: 1.5rem;">
  <%= message %>
</p>

<p style="color: #666; margin-bottom: 1.5rem;">
  An unexpected error occurred. Please try again later or contact the system administrator.
</p>

<% if (error && error.stack) { %>
  <div style="
    background: #f5f5f5;
    border: 1px solid #ddd;
    padding: 1rem;
    border-radius: 4px;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  ">
    <p style="color: #333; font-weight: bold; margin-bottom: 0.5rem;">Stack Trace:</p>
    <pre style="color: #666; font-size: 0.8rem; margin: 0;"><%= error.stack %></pre>
  </div>
<% } %>

<div style="text-align: center;">
  <a href="/" style="
    display: inline-block;
    background: #667eea;
    color: white;
    padding: 0.75rem 2rem;
    border-radius: 4px;
    text-decoration: none;
    font-weight: 500;
  ">
    ← Back to Home
  </a>
</div>
