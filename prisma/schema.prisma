// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Users table - main user data
model User {
  id        String   @id @default(cuid())
  name      String
  phone     String?  @unique
  password  String?
  status    UserStatus @default(created)
  lastLogin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  roles              UserRole[]
  activationTokens   ActivationToken[]

  @@map("users")
}

// User Status Enum
enum UserStatus {
  created
  active
  inactive
  blocked
}

// Roles table - role definitions
model Role {
  id   String @id @default(cuid())
  name String @unique

  // Relations
  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

// Permissions table - permission definitions
model Permission {
  id   String @id @default(cuid())
  name String @unique

  // Relations
  roles RolePermission[]

  @@map("permissions")
}

// User-Role junction table (many-to-many)
model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

// Role-Permission junction table (many-to-many)
model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// Activation Tokens for user account activation
model ActivationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiredAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activation_tokens")
}
